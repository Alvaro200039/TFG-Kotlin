<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_nuevo_nombre">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNombreSala"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/label_tamano"
        android:textColor="@android:color/black" />

    <Spinner
        android:id="@+id/spinnerTamanoSala"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/label_extras"
        android:textColor="@android:color/black" />

    <CheckBox
        android:id="@+id/cbWiFi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/extra_wifi" />

    <CheckBox
        android:id="@+id/cbProyector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/extra_proyector" />

    <CheckBox
        android:id="@+id/cbPizarra"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/extra_pizarra" />

</LinearLayout>
