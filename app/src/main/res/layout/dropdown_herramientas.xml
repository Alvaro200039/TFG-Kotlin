<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:shapeAppearanceOverlay="@style/Aura.Shape.TopRounded"
    app:cardElevation="12dp"
    android:layout_margin="0dp"
    app:cardBackgroundColor="?attr/colorSurfaceVariant"
    app:cardPreventCornerOverlap="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/menu_herramientas_titulo"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:paddingBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Diseñar Muros -->
            <LinearLayout
                android:id="@+id/btn_tool_muros"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_wall"
                    android:contentDescription="@string/desc_tool_muros"
                    app:tint="?attr/colorPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_muros"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>

            <!-- Añadir Sala -->
            <LinearLayout
                android:id="@+id/btn_tool_sala"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_meeting_room"
                    android:contentDescription="@string/desc_tool_sala"
                    app:tint="?attr/colorPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_sala"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>

            <!-- Añadir Puesto -->
            <LinearLayout
                android:id="@+id/btn_tool_puesto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_puesto"
                    android:contentDescription="@string/desc_tool_puesto"
                    app:tint="?attr/colorPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_puesto"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp"
                    android:textColor="?attr/colorOnSurface" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
